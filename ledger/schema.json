{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "receipt_id",
    "type",
    "source_url",
    "title",
    "first_seen_utc",
    "source_hash_sha256",
    "previous_hash",
    "chain_hash",
    "state",
    "notes"
  ],
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["PUBLIC_PAGE_OBSERVATION", "DATA_REQUEST_RECEIPT"] },
    "source_url": { "type": "string", "format": "uri" },
    "title": { "type": "string", "minLength": 1 },
    "first_seen_utc": { "type": "string", "format": "date-time" },
    "source_hash_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "previous_hash": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "chain_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "state": { "type": "string", "enum": ["seeded", "unchanged", "changed", "new"] },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
